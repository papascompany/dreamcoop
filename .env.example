# 드림상조 — 환경변수 예시 (실값은 .env.local 또는 Vercel 환경변수에 설정)

# 상담 신청 발송 채널 (택1). 미설정 시 서버 콘솔에 마스킹 로깅만 됨.
# 1) 웹훅: Slack Incoming Webhook / 알림톡 게이트웨이 / Zapier 등
# CONSULT_WEBHOOK_URL=

# 2) 이메일(Resend). https://resend.com 에서 발급. 발신 도메인 인증 필요.
# RESEND_API_KEY=
# CONSULT_TO_EMAIL=staff@example.com
# CONSULT_FROM_EMAIL=noreply@your-domain.kr
