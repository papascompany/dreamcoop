# 테이블: public.dreamcoop_landing  ·  스토리지 버킷: dreamcoop
SUPABASE_URL=https://uobbgxwuukwptqtywxxj.supabase.co
SUPABASE_ANON_KEY=sb_publishable_pcRdJNR92n1ArtTrGbM1IQ_zf4SX6b6
# ⚠️ 저장·이미지 업로드에 필요(서버 전용 시크릿). 미설정 시 사이트 읽기는 되지만 관리자 저장이 비활성화됨.
#    Supabase 대시보드 > storige > Project Settings > API > service_role secret 에서 복사.
SUPABASE_SERVICE_ROLE_KEY=

# ── 관리자 로그인 (/admin/login) ──
ADMIN_PASSWORD=change-me
# 세션 쿠키 서명용 — 32바이트 이상 랜덤 hex 권장: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace-with-random-hex

# ── 상담 신청 발송 채널 (택1). 미설정 시 서버 콘솔에 마스킹 로깅만 됨. ──
# 1) 웹훅: Slack Incoming Webhook / 알림톡 게이트웨이 / Zapier 등
# CONSULT_WEBHOOK_URL=
# 2) 이메일(Resend). https://resend.com 에서 발급. 발신 도메인 인증 필요.
# RESEND_API_KEY=
# CONSULT_TO_EMAIL=staff@example.com
# CONSULT_FROM_EMAIL=noreply@your-domain.kr
